# MS SQL Database Configuration (Windows Authentication)
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=HackathonDB
DB_INSTANCE=
# Windows Authentication kullanıyorsanız aşağıdaki satırları boş bırakın
DB_USER=
DB_PASSWORD=
DB_DOMAIN=

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret Key
JWT_SECRET=hackathon-secret-key-2025-deepfake-detection

# Hugging Face API Configuration
# Model: prithivMLmods/deepfake-detector-model-v1 (Image Classification, Accuracy: 94.44%)
# API Key almak için: https://huggingface.co/settings/tokens
# Dokümantasyon: HUGGINGFACE_API_GUIDE.md dosyasına bakın
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL_ENDPOINT=https://api-inference.huggingface.co/models/prithivMLmods/deepfake-detector-model-v1